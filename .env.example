# Angel AI Service Configuration

# Service authentication (shared secret with KPI backend)
SERVICE_TOKEN_SECRET=your-secret-token-here

# LLM backend
LLM_BACKEND=gemini

# Gemini API (Developer API)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TIMEOUT_SECONDS=120
GEMINI_TEMPERATURE=1.0
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_FUNCTION_CALLING_MODE=AUTO

# Claude CLI
CLAUDE_CLI_PATH=claude
CLAUDE_MODEL=sonnet
CLAUDE_TIMEOUT_SECONDS=120
CLAUDE_MAX_BUDGET_USD=0.50

# KPI Database (read-only access)
KPI_DATABASE_URL=mysql+pymysql://readonly:password@localhost/angel_kpi
BI_SQLSERVER_URL=

# MCP Server
MCP_SERVER_SCRIPT=C:/Projects/angel-ai-service/mcp_server.py
MCP_PYTHON_PATH=python

# Rate limits
MAX_REQUESTS_PER_USER_PER_DAY=100
MAX_CONCURRENT_REQUESTS=3

# Storage
SQLITE_DB_PATH=C:/Projects/angel-ai-service/data/ai_service.db
SYSTEM_PROMPT_PATH=C:/Projects/angel-ai-service/prompts/system_prompt.txt
